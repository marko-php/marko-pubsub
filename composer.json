{
    "name": "marko/pubsub",
    "description": "Pub/sub interfaces and value objects for Marko Framework",
    "type": "marko-module",
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "marko/core": "@dev"
    },
    "require-dev": {
        "marko/testing": "@dev",
        "pestphp/pest": "^4.0"
    },
    "autoload": {
        "psr-4": {
            "Marko\\PubSub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Marko\\PubSub\\Tests\\": "tests/"
        }
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "marko": {
            "module": true
        }
    }
}
